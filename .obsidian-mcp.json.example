{
  "primaryVaults": [
    {
      "path": "~/Documents/Obsidian/MainVault",
      "name": "Main Vault",
      "mode": "work"
    },
    {
      "path": "~/Documents/Obsidian/PersonalVault",
      "name": "Personal Vault",
      "mode": "personal"
    }
  ],
  "secondaryVaults": [
    {
      "path": "~/Documents/Obsidian/WorkDocs",
      "name": "Work Documentation",
      "authority": "curated",
      "mode": "work"
    },
    {
      "path": "~/Documents/Obsidian/PersonalNotes",
      "name": "Personal Notes",
      "authority": "curated",
      "mode": "personal"
    }
  ],
  "security": {
    "accessControl": {
      "allowedPaths": [
        "~/.claude",
        "~/Projects",
        "~/Documents"
      ]
    }
  }
}
