{
  "name": "obsidian-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Claude Code integration with Obsidian vault",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "obsidian-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp .obsidian-mcp.json dist/ 2>/dev/null || true",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsc && cp .obsidian-mcp.json dist/ 2>/dev/null || true && node dist/index.js",
    "test": "npm run build && node dist/test.js",
    "clean": "rm -rf dist",
    "setup": "./setup.sh"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "claude",
    "context",
    "note-taking"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.37",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
